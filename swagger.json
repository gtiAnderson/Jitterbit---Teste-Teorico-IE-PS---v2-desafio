{
  "openapi": "3.0.0",
  "info": {
    "title": "Jitterbit Order API",
    "version": "1.0.0",
    "description": "API para gerenciamento de pedidos com mapping de dados e autenticação JWT",
    "contact": {
      "name": "Anderson Moreira Amaral",
      "url": "https://www.linkedin.com/in/andersonnmoreira/"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "OrderItem": {
        "type": "object",
        "properties": {
          "idItem": { "type": "string", "example": "2434" },
          "quantidadeItem": { "type": "number", "example": 1 },
          "valorItem": { "type": "number", "example": 1000 }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "numeroPedido": { "type": "string", "example": "v10089015vdb-01" },
          "valorTotal": { "type": "number", "example": 10000 },
          "dataCriacao": { "type": "string", "example": "2023-07-19T12:24:11.529Z" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OrderItem" }
          }
        }
      }
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Gera o token de autenticação JWT",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "user": { "type": "string", "example": "anderson" },
                  "password": { "type": "string", "example": "admin123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Token gerado com sucesso" },
          "401": { "description": "Credenciais inválidas" }
        }
      }
    },
    "/order": {
      "post": {
        "summary": "Cria um novo pedido (Mapping automático)",
        "tags": ["Orders"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Order" }
            }
          }
        },
        "responses": {
          "201": { "description": "Pedido criado com sucesso" },
          "401": { "description": "Não autorizado" }
        }
      }
    },
    "/order/list": {
      "get": {
        "summary": "Lista todos os pedidos cadastrados",
        "tags": ["Orders"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Sucesso" },
          "401": { "description": "Não autorizado" }
        }
      }
    },
    "/order/{numeroPedido}": {
      "get": {
        "summary": "Busca um pedido pelo ID (numeroPedido)",
        "tags": ["Orders"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "numeroPedido",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Pedido encontrado" },
          "404": { "description": "Pedido não encontrado" }
        }
      },
      "put": {
        "summary": "Atualiza um pedido existente",
        "tags": ["Orders"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "numeroPedido",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Order" }
            }
          }
        },
        "responses": {
          "200": { "description": "Pedido atualizado com sucesso" },
          "404": { "description": "Pedido não encontrado" }
        }
      },
      "delete": {
        "summary": "Deleta um pedido do sistema",
        "tags": ["Orders"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "numeroPedido",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Pedido deletado com sucesso" },
          "404": { "description": "Pedido não encontrado" }
        }
      }
    }
  }
}